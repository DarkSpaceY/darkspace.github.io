---
import { getCollection } from "astro:content";
import { getTagList } from "../../utils/content-utils";

const allPosts = await getCollection("posts", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const tags = await getTagList();

const postCount = allPosts.length;
const tagCount = tags.length;

const firstPost = [...allPosts].sort(
  (a, b) => new Date(a.data.published).getTime() - new Date(b.data.published).getTime()
)[0];
const siteBirth = firstPost ? new Date(firstPost.data.published) : new Date();
const daysSince = Math.floor(
  (Date.now() - siteBirth.getTime()) / (1000 * 60 * 60 * 24)
);
---

<div class="card-base p-3 onload-animation" style="animation-delay: 125ms">
  <div class="flex items-center justify-between">
    <div class="text-center flex-1">
      <div class="text-lg font-bold text-[var(--primary)]">{postCount}</div>
      <div class="text-[10px] text-50">文章</div>
    </div>
    <div class="w-px h-6 bg-[var(--line-color)]"></div>
    <div class="text-center flex-1">
      <div class="text-lg font-bold text-[var(--primary)]">{tagCount}</div>
      <div class="text-[10px] text-50">标签</div>
    </div>
    <div class="w-px h-6 bg-[var(--line-color)]"></div>
    <div class="text-center flex-1">
      <div class="text-lg font-bold text-[var(--primary)]">{daysSince}</div>
      <div class="text-[10px] text-50">天</div>
    </div>
  </div>
</div>
